generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                Int               @id @default(autoincrement())
  name              String
  faceLabel         String            @unique
  faceDescriptor    String?
  location          String            @default("Amsterdam")
  preferredLanguage String            @default("en")
  createdAt         DateTime          @default(now())
  events            CalendarEvent[]
  reminders         Reminder[]
  voiceLogs         VoiceCommandLog[]
  activeMirrorState MirrorState? @relation("ActiveUser")
}

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  startTime   DateTime
  endTime     DateTime
  location    String?
  description String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Reminder {
  id         Int      @id @default(autoincrement())
  userId     Int
  text       String
  dueAt      DateTime?
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VoiceCommandLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  transcript String
  intent    String
  response  String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model MirrorState {
  id                   Int   @id @default(autoincrement())
  activeUserId         Int?  @unique
  registrationComplete Boolean @default(false)
  activeUser           User? @relation("ActiveUser", fields: [activeUserId], references: [id], onDelete: SetNull)
}

model WeatherCache {
  id         Int      @id @default(autoincrement())
  locationKey String  @unique
  location   String
  payload    String
  fetchedAt  DateTime
}
